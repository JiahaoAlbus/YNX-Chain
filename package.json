{
  "name": "ynx-chain-contract-tooling",
  "private": true,
  "type": "module",
  "scripts": {
    "contracts:check": "bash ./scripts/verify/contract-tooling-check.sh",
    "contracts:selectors": "node ./scripts/contracts/generate-selector-metadata.mjs",
    "hardhat:build": "hardhat build",
    "dex:contracts:test": "hardhat run ./scripts/dex/contract-test.mjs --network dexTest",
    "dex:deploy:testnet": "hardhat run ./scripts/dex/deploy-testnet.mjs --network ynxTestnet",
    "dex:manifests:check": "node ./scripts/dex/check-manifests.mjs",
    "dex:testnet:probe": "node ./scripts/dex/probe-testnet.mjs",
    "dex:package:all": "npm run hardhat:build && npm run package:pwa --prefix apps/dex && node ./scripts/dex/package-all.mjs",
    "dex:artifacts:verify": "node ./scripts/dex/verify-artifacts.mjs",
    "hardhat:deploy:ynx-testnet": "hardhat run ./scripts/contracts/deploy-samples-hardhat.js --network ynxTestnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.13",
    "ethers": "^6.17.0",
    "hardhat": "^3.9.0",
    "typescript": "^5.9.0",
    "undici": "^6.27.0"
  }
}
