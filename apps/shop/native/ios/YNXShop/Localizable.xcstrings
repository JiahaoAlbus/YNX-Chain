    "payment_boundary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An order is paid only after exact committed YNXT evidence from Central Pay."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有中央支付返回完全匹配且已提交的 YNXT 证据后，订单才会标记为已支付。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "只有中央支付回傳完全相符且已提交的 YNXT 證據後，訂單才會標為已付款。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "中央 Pay の完全一致する確定 YNXT 証拠がある場合のみ支払い済みになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "중앙 Pay의 정확히 일치하는 확정 YNXT 증거가 있을 때만 결제 완료로 표시됩니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un pedido solo se marca pagado con evidencia YNXT confirmada y exacta de Central Pay."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une commande n’est payée qu’avec une preuve YNXT exacte et confirmée de Central Pay."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Bestellung gilt nur mit exakt passendem, bestätigtem YNXT-Nachweis von Central Pay als bezahlt."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Um pedido só é pago com evidência YNXT exata e confirmada do Central Pay."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Заказ считается оплаченным только при точном подтверждённом доказательстве YNXT от Central Pay."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يُعد الطلب مدفوعاً إلا بدليل YNXT مطابق ومؤكد من Central Pay."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pesanan hanya dianggap dibayar setelah bukti YNXT Central Pay yang tepat dan terkonfirmasi."
          }
        }
      }
    },
    "wallet_security": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet signs the account approval. This App signs a separate P-256 device challenge. No recovery key enters Shop."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "钱包只签署账户授权；本应用另行签署 P-256 设备挑战。恢复密钥不会进入商城。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "錢包只簽署帳戶授權；本 App 另行簽署 P-256 裝置挑戰。復原密鑰不會進入商城。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet はアカウント承認だけに署名し、このアプリは別の P-256 デバイスチャレンジに署名します。復旧キーは Shop に渡りません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet은 계정 승인에만 서명하고 앱은 별도 P-256 기기 챌린지에 서명합니다. 복구 키는 Shop에 전달되지 않습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet firma la autorización de la cuenta y esta app firma un reto P-256 separado. Ninguna clave de recuperación entra en Shop."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet signe l’autorisation du compte et l’app signe un défi P-256 séparé. Aucune clé de récupération n’entre dans Shop."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet signiert die Kontoautorisierung; die App signiert eine separate P-256-Geräteprüfung. Kein Wiederherstellungsschlüssel gelangt in Shop."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet assina a autorização da conta e o app assina um desafio P-256 separado. Nenhuma chave de recuperação entra na Shop."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet подписывает разрешение аккаунта, а приложение — отдельный вызов устройства P-256. Ключ восстановления не попадает в Shop."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "توقّع المحفظة تفويض الحساب ويوقّع التطبيق تحدي جهاز P-256 منفصلاً. لا يدخل مفتاح الاسترداد إلى المتجر."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet menandatangani persetujuan akun dan aplikasi menandatangani tantangan perangkat P-256 terpisah. Kunci pemulihan tidak masuk ke Shop."
          }
        }
      }
    },
    "privacy_boundary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Profile, address and orders stay in Shop. AI receives only the context shown before permission."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "个人资料、地址和订单保留在商城内。AI 仅在授权前接收明确展示的上下文。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "個人資料、地址與訂單保留在商城。AI 僅在授權前接收畫面所示內容。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロフィール、住所、注文は Shop 内に保持されます。AI には許可前に表示したコンテキストだけを渡します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프로필, 주소, 주문은 Shop에 보관됩니다. AI는 권한 전에 표시된 컨텍스트만 받습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Perfil, dirección y pedidos permanecen en Shop. La IA solo recibe el contexto mostrado antes del permiso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil, adresse et commandes restent dans Shop. L’IA ne reçoit que le contexte affiché avant autorisation."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil, Adresse und Bestellungen bleiben in Shop. KI erhält nur den vor der Freigabe gezeigten Kontext."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Perfil, endereço e pedidos ficam na Shop. A IA recebe apenas o contexto exibido antes da permissão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Профиль, адрес и заказы остаются в Shop. ИИ получает только показанный до разрешения контекст."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يبقى الملف والعنوان والطلبات داخل المتجر. لا يتلقى الذكاء الاصطناعي إلا السياق المعروض قبل الإذن."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil, alamat, dan pesanan tetap di Shop. AI hanya menerima konteks yang ditampilkan sebelum izin."
          }
        }
      }
    },
    "offline": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Offline. No success is simulated."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前离线，不会模拟成功。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前離線，不會模擬成功。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフラインです。成功を装いません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오프라인입니다. 성공으로 가장하지 않습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin conexión. No se simula ningún éxito."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hors ligne. Aucun succès n’est simulé."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Offline. Erfolg wird nicht simuliert."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Offline. Nenhum sucesso é simulado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет сети. Успех не имитируется."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير متصل. لا تتم محاكاة النجاح."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Luring. Keberhasilan tidak disimulasikan."
          }
        }
      }
    },
    "security_error": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Security verification failed."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安全验证失败。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "安全驗證失敗。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セキュリティ検証に失敗しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보안 검증에 실패했습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Falló la verificación de seguridad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La vérification de sécurité a échoué."
          }
        },
        "de": {
