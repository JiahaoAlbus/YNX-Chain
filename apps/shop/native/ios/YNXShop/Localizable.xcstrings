    "trust_boundary": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only submitted Trust case evidence is shown; Trust cannot move payment."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅显示已提交的 Trust 案件证据；Trust 不能划转付款。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅顯示已提交的 Trust 案件證據；Trust 不能移轉付款。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "提出済みのTrust証拠のみ表示し、Trustは支払いを移動できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제출된 Trust 사건 증거만 표시되며 Trust는 결제를 이동할 수 없습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se muestra evidencia enviada a Trust; Trust no puede mover pagos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seules les preuves soumises à Trust sont affichées ; Trust ne peut déplacer aucun paiement."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur eingereichte Trust-Nachweise werden gezeigt; Trust kann keine Zahlung bewegen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas evidências enviadas ao Trust são exibidas; o Trust não pode mover pagamentos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показаны только переданные в Trust доказательства; Trust не может переводить платежи."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُعرض فقط دليل قضية Trust المرسل؛ ولا يمكن لـ Trust نقل المدفوعات."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hanya bukti kasus Trust yang dikirim ditampilkan; Trust tidak dapat memindahkan pembayaran."
          }
        }
      }
    },
