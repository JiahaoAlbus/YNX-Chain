    "ai_privacy": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AI sees only the selected public catalog or owned order summary. It cannot buy, refund, publish, price, or change policy."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 仅查看所选公开商品或本人订单摘要，不能购买、退款、发布商品、改价或修改政策。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 僅查看所選公開商品或本人訂單摘要，不能購買、退款、發布商品、改價或修改政策。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AIが見るのは選択した公開カタログまたは所有注文の要約だけです。購入、返金、公開、価格変更、ポリシー変更はできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI는 선택한 공개 카탈로그 또는 본인 주문 요약만 봅니다. 구매, 환불, 게시, 가격 또는 정책 변경은 할 수 없습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La IA solo ve el catálogo público elegido o el resumen de un pedido propio. No puede comprar, reembolsar, publicar, cambiar precios ni políticas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’IA ne voit que le catalogue public sélectionné ou le résumé d’une commande possédée. Elle ne peut ni acheter, rembourser, publier, modifier un prix ou une politique."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die KI sieht nur den gewählten öffentlichen Katalog oder die Zusammenfassung einer eigenen Bestellung. Sie kann weder kaufen, erstatten, veröffentlichen noch Preise oder Richtlinien ändern."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A IA vê apenas o catálogo público selecionado ou o resumo de um pedido seu. Não pode comprar, reembolsar, publicar, alterar preço ou política."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ИИ видит только выбранный публичный каталог или сводку вашего заказа. Он не может покупать, возвращать средства, публиковать, менять цену или правила."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يرى الذكاء الاصطناعي إلا الكتالوج العام المحدد أو ملخص طلب تملكه. لا يمكنه الشراء أو الاسترداد أو النشر أو تغيير السعر أو السياسة."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "AI hanya melihat katalog publik terpilih atau ringkasan pesanan milik Anda. AI tidak dapat membeli, mengembalikan dana, menerbitkan, mengubah harga, atau kebijakan."
          }
        }
      }
    },
