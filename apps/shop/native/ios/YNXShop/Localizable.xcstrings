            "state": "translated",
            "value": "Falha na verificação de segurança."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверка безопасности не пройдена."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل التحقق الأمني."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifikasi keamanan gagal."
          }
        }
      }
    },
    "queued_offline": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Action queued with its idempotency key; no order or payment is claimed until server confirmation."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "操作已连同幂等键排队；服务器确认前不会声称订单或付款成功。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "操作已連同冪等鍵排隊；伺服器確認前不會宣稱訂單或付款成功。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "冪等キー付きで待機中です。サーバー確認までは注文や支払いの成功と表示しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "멱등성 키와 함께 대기 중이며 서버 확인 전에는 주문이나 결제 성공으로 표시하지 않습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acción en cola con su clave idempotente; no se confirma pedido ni pago hasta la respuesta del servidor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Action mise en file avec sa clé d’idempotence ; aucune commande ni paiement n’est confirmé avant le serveur."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktion mit Idempotenzschlüssel vorgemerkt; Bestellung oder Zahlung gilt erst nach Serverbestätigung."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ação enfileirada com chave de idempotência; nenhum pedido ou pagamento é confirmado antes do servidor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Действие поставлено в очередь с ключом идемпотентности; заказ или оплата подтверждаются только сервером."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وُضع الإجراء في قائمة الانتظار مع مفتاح عدم التكرار؛ لا يُدّعى إنشاء طلب أو دفع قبل تأكيد الخادم."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tindakan diantrekan dengan kunci idempotensi; pesanan atau pembayaran tidak diklaim sampai konfirmasi server."
          }
        }
      }
    },
    "signing_text": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authorize YNX Shop on ynx_6423-1 for the exact scopes shown. Expires in four minutes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按所示精确权限授权 YNX 商城访问 ynx_6423-1；四分钟后过期。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "依顯示的精確權限授權 YNX 商城存取 ynx_6423-1；四分鐘後到期。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "表示された正確な権限でYNX Shopのynx_6423-1利用を承認します。4分で失効します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "표시된 정확한 범위로 YNX Shop의 ynx_6423-1 사용을 승인합니다. 4분 후 만료됩니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Autoriza YNX Shop en ynx_6423-1 con los permisos exactos mostrados. Caduca en cuatro minutos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorisez YNX Shop sur ynx_6423-1 avec les portées exactes affichées. Expire dans quatre minutes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "YNX Shop für ynx_6423-1 mit den exakt angezeigten Bereichen autorisieren. Läuft in vier Minuten ab."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorize o YNX Shop em ynx_6423-1 com os escopos exatos mostrados. Expira em quatro minutos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешить YNX Shop работу в ynx_6423-1 с указанными точными правами. Срок — четыре минуты."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فوّض متجر YNX على ynx_6423-1 بالنطاقات الدقيقة المعروضة. تنتهي الصلاحية خلال أربع دقائق."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Izinkan YNX Shop di ynx_6423-1 dengan cakupan tepat yang ditampilkan. Kedaluwarsa dalam empat menit."
          }
        }
      }
    },
