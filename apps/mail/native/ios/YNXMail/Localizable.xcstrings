    "privacy": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only selected threads are sent to AI after approval."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在批准后将所选会话发送给 AI。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "只有在核准後才會將所選討論串傳送給 AI。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "承認後、選択したスレッドだけをAIに送信します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "승인 후 선택한 대화만 AI로 전송됩니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo los hilos seleccionados se envían a la IA tras la aprobación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seules les conversations sélectionnées sont envoyées à l’IA après approbation."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur ausgewählte Unterhaltungen werden nach Freigabe an die KI gesendet."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Somente conversas selecionadas são enviadas à IA após aprovação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только выбранные цепочки отправляются ИИ после подтверждения."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا تُرسل إلى الذكاء الاصطناعي إلا المحادثات المحددة وبعد الموافقة."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hanya percakapan yang dipilih yang dikirim ke AI setelah persetujuan."
          }
        }
      }
    },
