    "security": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet approval never shares recovery material."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "钱包批准绝不会共享恢复材料。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "錢包核准絕不會分享復原資料。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Walletの承認で復旧情報が共有されることはありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet 승인은 복구 자료를 공유하지 않습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La aprobación de Wallet nunca comparte material de recuperación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’approbation Wallet ne partage jamais les données de récupération."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Wallet-Freigabe gibt niemals Wiederherstellungsmaterial weiter."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A aprovação da Wallet nunca compartilha material de recuperação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подтверждение Wallet никогда не раскрывает данные восстановления."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "موافقة المحفظة لا تشارك مواد الاسترداد مطلقًا."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Persetujuan Wallet tidak pernah membagikan materi pemulihan."
          }
        }
      }
    },
