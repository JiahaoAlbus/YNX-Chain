    "privacy": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only selected event details are sent to AI after approval."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有批准后才会把选中的日程详情发送给 AI。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "只有核准後才會將所選活動詳情傳送給 AI。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "承認後、選択した予定の詳細だけをAIに送信します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "승인 후 선택한 일정 정보만 AI로 전송됩니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo los detalles seleccionados se envían a la IA tras la aprobación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seuls les détails sélectionnés sont envoyés à l’IA après approbation."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur ausgewählte Termindetails werden nach Freigabe an die KI gesendet."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Somente detalhes selecionados são enviados à IA após aprovação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только выбранные сведения отправляются ИИ после подтверждения."
