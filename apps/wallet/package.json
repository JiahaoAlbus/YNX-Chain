{
  "name": "@ynx-chain/wallet-app",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "tsx --test src/*.test.ts src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "bundle:android": "expo export --platform android --output-dir dist-android",
    "bundle:ios": "expo export --platform ios --output-dir dist-ios",
    "bundle": "npm run bundle:android && npm run bundle:ios",
    "product-check": "node scripts/product-check.mjs",
    "check": "npm run typecheck && npm test && npm run product-check && npm run bundle"
  },
  "dependencies": {
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@ynx-chain/wallet-auth": "file:../../packages/wallet-auth",
    "expo": "~57.0.4",
    "expo-clipboard": "57.0.0",
    "expo-crypto": "~57.0.0",
    "expo-local-authentication": "~57.0.0",
    "expo-screen-capture": "57.0.0",
    "expo-secure-store": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "lucide-react-native": "1.24.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-qrcode-svg": "6.3.21",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "tsx": "4.23.1",
    "typescript": "~6.0.3"
  },
  "overrides": {"@expo/package-manager":"1.13.0","@expo/prebuild-config":"57.0.5","@expo/schema-utils":"57.0.1","expo-server":"57.0.0"}
}
