{
  "expo": {
    "name": "YNX",
    "slug": "ynx-chain",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ynx",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ynxweb4.mobile",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.ynxweb4.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow YNX to unlock your locally held account keys."
        }
      ],
      "./plugins/withYnxAndroidReleaseSigning"
    ]
  }
}
