YNX_MONITOR_PORT=4675
YNX_MONITOR_SESSION_SECRET=
# JSON array: [{"username":"name","role":"viewer|operator","passwordHash":"scrypt hex"}]
YNX_MONITOR_USERS=
YNX_MONITOR_STATE_PATH=tmp/monitor/state.json
YNX_MONITOR_RPC_URL=http://127.0.0.1:6420
YNX_MONITOR_EXPLORER_URL=http://127.0.0.1:6427
YNX_MONITOR_INDEXER_URL=http://127.0.0.1:6426
YNX_MONITOR_AI_URL=http://127.0.0.1:6429
# Server-side only. Enables advisory incident summaries.
YNX_MONITOR_AI_KEY=
# JSON object of safe names to local file paths, for example {"chain":"/var/log/ynx/chain.log"}
YNX_MONITOR_LOG_SOURCES={}
