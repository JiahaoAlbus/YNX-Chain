    "tsx": "4.21.0",
    "vite": "8.1.4",
    "typescript": "5.8.3",
    "@types/express": "5.0.6",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  },
  "overrides": {
    "esbuild": "0.28.1"
