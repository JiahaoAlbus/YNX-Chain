# Copy to a secret runtime environment. Do not commit real values.
YNX_AI_CLIENT_HTTP_ADDR=127.0.0.1:6438
YNX_AI_CLIENT_STATE_PATH=/absolute/private/path/ynx-ai-client-state.json
YNX_AI_CLIENT_CONTENT_KEY=<32-byte-hex-or-raw-base64-key>
YNX_AI_CLIENT_GATEWAY_URL=http://127.0.0.1:6429
YNX_AI_GATEWAY_API_KEY=<server-side-gateway-access-key>
YNX_AI_CLIENT_WALLET_CALLBACK=ynxai://wallet-auth/callback
YNX_AI_CLIENT_TRUST_URL=https://trust.ynxweb4.com/appeals
YNX_AI_CLIENT_PROVIDER_NAME=configured OpenAI-compatible provider
YNX_AI_CLIENT_GENERATION_TIMEOUT=45s

# Optional operator-supplied estimates. Leave zero/unset to show money unknown.
YNX_AI_CLIENT_INPUT_USD_PER_MILLION=0
YNX_AI_CLIENT_OUTPUT_USD_PER_MILLION=0
YNX_AI_CLIENT_RESOURCE_UNITS_PER_KTOKENS=1
