{
  "title": "YNX Chain Testnet",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "Height",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "ynx_chain_height", "legendFormat": "height" }]
    },
    {
      "type": "timeseries",
      "title": "Block Progress",
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "ynx_chain_height", "legendFormat": "{{network}}" }]
    },
    {
      "type": "stat",
      "title": "Transactions",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "ynx_chain_transactions_total", "legendFormat": "tx" }]
    },
    {
      "type": "timeseries",
      "title": "Pending Transactions",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 7 },
      "targets": [{ "expr": "ynx_chain_pending_transactions", "legendFormat": "pending" }]
    },
    {
      "type": "timeseries",
      "title": "Pay / Trust / Contracts",
      "gridPos": { "x": 8, "y": 8, "w": 10, "h": 7 },
      "targets": [
        { "expr": "ynx_chain_pay_intents_total", "legendFormat": "pay intents" },
        { "expr": "ynx_chain_trust_evidence_total", "legendFormat": "trust evidence" },
        { "expr": "ynx_chain_contracts_total", "legendFormat": "contracts" }
      ]
    },
    {
      "type": "stat",
      "title": "Persistence Error",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [{ "expr": "ynx_chain_persistence_error", "legendFormat": "error" }]
    },
    {
      "type": "timeseries",
      "title": "Explorer Sync Lag",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 7 },
      "targets": [{ "expr": "ynx_explorer_sync_lag_blocks", "legendFormat": "explorer lag" }]
    },
    {
      "type": "stat",
      "title": "Explorer Visible Transactions",
      "gridPos": { "x": 12, "y": 15, "w": 6, "h": 4 },
      "targets": [{ "expr": "ynx_explorer_transactions_total", "legendFormat": "indexed tx" }]
    },
    {
      "type": "timeseries",
      "title": "Faucet Requests",
      "gridPos": { "x": 18, "y": 15, "w": 6, "h": 7 },
      "targets": [
        { "expr": "ynx_faucet_requests_total", "legendFormat": "requests" },
        { "expr": "ynx_faucet_success_total", "legendFormat": "success" },
        { "expr": "ynx_faucet_denied_total", "legendFormat": "denied" }
      ]
    },
    {
      "type": "stat",
      "title": "Follower Replication Health",
      "gridPos": { "x": 0, "y": 22, "w": 8, "h": 5 },
      "targets": [
        { "expr": "ynx_chain_replication_fresh{job=\"ynx-chaind\"}", "legendFormat": "{{instance}} fresh" },
        { "expr": "ynx_chain_replication_catching_up{job=\"ynx-chaind\"}", "legendFormat": "{{instance}} catching up" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Follower Replication Lag",
      "gridPos": { "x": 8, "y": 22, "w": 8, "h": 7 },
      "targets": [
        { "expr": "ynx_chain_replication_lag_blocks{job=\"ynx-chaind\"}", "legendFormat": "{{instance}} lag" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Follower Replication Failures",
      "gridPos": { "x": 16, "y": 22, "w": 8, "h": 7 },
      "targets": [
        { "expr": "increase(ynx_chain_replication_failures_total{job=\"ynx-chaind\"}[5m])", "legendFormat": "{{instance}} failures" },
        { "expr": "ynx_chain_replication_consecutive_failures{job=\"ynx-chaind\"}", "legendFormat": "{{instance}} consecutive" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Economics Disclosure Request and Error Rate",
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 7 },
      "targets": [
        { "expr": "rate(ynx_explorer_economics_disclosure_requests_total{job=\"ynx-explorerd\"}[5m])", "legendFormat": "requests/s" },
        { "expr": "rate(ynx_explorer_economics_disclosure_errors_total{job=\"ynx-explorerd\"}[5m])", "legendFormat": "errors/s" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Economics Disclosure Latency",
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 7 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(ynx_explorer_economics_disclosure_latency_seconds_bucket{job=\"ynx-explorerd\"}[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(ynx_explorer_economics_disclosure_latency_seconds_bucket{job=\"ynx-explorerd\"}[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(ynx_explorer_economics_disclosure_latency_seconds_bucket{job=\"ynx-explorerd\"}[5m])))", "legendFormat": "p99" }
      ]
    }
  ]
}
