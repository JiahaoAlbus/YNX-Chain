YNX_DEX_HTTP_ADDR=127.0.0.1:6436
YNX_DEX_STATE_PATH=tmp/dex/indexer-state.json
YNX_DEX_TOKEN_LIST_PATH=token-lists/dex-testnet.json
# Generate at deployment time. Unpadded base64 encoding of >=32 random bytes.
YNX_DEX_STATE_HMAC_SECRET=
# Separate >=32-character secret used only by the trusted EVM event ingester.
YNX_DEX_INDEXER_INGESTION_KEY=
# Canonical central Gateway introspection endpoint after registry integration.
YNX_DEX_WALLET_INTROSPECTION_URL=
YNX_EVM_RPC_URL=https://evm.ynxweb4.com
# Set only after a verified deployment manifest exists.
DEX_FACTORY_ADDRESS=
DEX_QUOTER_ADDRESS=
DEX_INDEXER_START_BLOCK=
DEX_INDEXER_CONFIRMATIONS=12
YNX_DEX_CURSOR_PATH=tmp/dex/evm-cursor.json
# Never commit or place this value in Web/PWA configuration.
DEPLOYER_PRIVATE_KEY=
# Candidate should be an owner-controlled Testnet multisig, not a browser key.
DEX_GOVERNANCE_ADDRESS=
DEX_PROTOCOL_FEE_RECIPIENT=
# JSON array of reviewed Testnet ERC-20 addresses, including wrapped YNXT.
DEX_INITIAL_TOKEN_ADDRESSES=[]
DEX_DEPLOYMENT_MANIFEST_PATH=tmp/dex/deployment-manifest.json
# Browser-visible AI configuration must be a same-origin path served by the canonical gateway.
VITE_DEX_AI_GATEWAY_URL=
VITE_DEX_AI_PROVIDER=canonical YNX AI Gateway
VITE_DEX_AI_MODEL=risk-explainer-v1
