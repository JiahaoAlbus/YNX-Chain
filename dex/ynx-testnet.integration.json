{
  "schemaVersion": 2,
  "productId": "ynx-dex",
  "mainnet": false,
  "audited": false,
  "productionLiquidity": false,
  "deploymentStatus": "not-deployed",
  "network": {
    "name": "YNX Testnet",
    "chainId": 6423,
    "nativeCurrency": {
      "name": "YNXT",
      "symbol": "YNXT",
      "decimals": 18
    }
  },
  "rpc": {
    "requiredEnv": "YNX_EVM_RPC_URL",
    "status": "real public EVM RPC URL required before external DEX submission"
  },
  "deployments": {
    "wrappedYNXT": {
      "addressEnv": "WRAPPED_YNXT_ADDRESS",
      "address": null,
      "status": "required before liquidity pool launch"
    },
    "factory": {
      "addressEnv": "DEX_FACTORY_ADDRESS",
      "address": null,
      "status": "required before DEX indexing"
    },
    "router": {
      "addressEnv": "DEX_ROUTER_ADDRESS",
      "address": null,
      "status": "required before swap UI integration"
    },
    "quoter": {
      "addressEnv": "DEX_QUOTER_ADDRESS",
      "address": null,
      "status": "required before independent quote verification"
    },
    "strategyVault": {
      "addressEnv": "DEX_STRATEGY_VAULT_ADDRESS",
      "address": null,
      "status": "required before Quant execution; owner must configure mandate on-chain after deployment"
    },
    "fairFlow": {
      "addressEnv": "DEX_FAIRFLOW_ADDRESS",
      "address": null,
      "status": "required before Intent or Solver activation; treasury and minimum native bond must match the verified deployment manifest"
    },
    "lpProtection": {
      "addressEnv": "derived from DEX_FACTORY_ADDRESS",
      "address": null,
      "status": "required protected-factory child contract; must match factory.lpProtection() and verified source"
    },
    "lpProtectionOracle": {
      "addressEnv": "DEX_LP_PROTECTION_ORACLE_ADDRESS",
      "address": null,
      "status": "owner-reviewed on-chain adapter required; upstream source, heartbeat and depeg semantics must be published"
    },
    "multicall": {
      "addressEnv": "MULTICALL_ADDRESS",
      "address": null,
      "status": "required before portfolio and analytics indexing"
    }
  },
  "indexing": {
    "eventCoverage": ["PoolCreated", "Swap", "Mint", "Burn", "Sync", "ProtocolFeesClaimed", "LP Transfer correlation", "Strategy Vault ActionExecuted", "FairFlow Intent/Commit/Reveal/Winner/Settlement/Slash"],
    "logSource": "YNX Testnet EVM JSON-RPC",
    "startBlockEnv": "DEX_INDEXER_START_BLOCK",
    "confirmationsEnv": "DEX_INDEXER_CONFIRMATIONS",
    "cursorIntegrity": "HMAC-SHA-256",
    "reorgRecovery": "rewind confirmed pool, Vault and FairFlow events plus pool discovery, then rescan",
    "stateSchemaVersion": 3,
    "cursorSchemaVersion": 3,
    "vaultAddressEnv": "DEX_STRATEGY_VAULT_ADDRESS",
    "fairFlowAddressEnv": "DEX_FAIRFLOW_ADDRESS",
    "fairFlowIndexerStatus": "implemented and tested locally; requires a verified deployed address before live ingestion"
  },
  "verification": {
    "contractVerifierUrlEnv": "YNX_CONTRACT_VERIFIER_URL",
    "compilerVersion": "0.8.24",
    "command": "make contract-tooling-check"
  }
}
