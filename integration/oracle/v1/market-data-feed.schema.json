{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ynx:oracle:v1:market-data-feed",
  "title": "YNX Oracle normalized structured market data feed",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "market", "type", "source", "version", "asOf", "producedAt", "sourceCount", "coveragePpm", "stale", "items"],
  "properties": {
    "schema": {"const": "ynx.oracle.v1"},
    "market": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._/-]{2,63}$"},
    "type": {"enum": ["ohlcv", "trades", "clob_order_book", "dex_pool_state", "provider_status"]},
    "source": {"const": "YNX Oracle normalized signed provider events"},
    "version": {"const": "observation-normalizer-v1"},
    "asOf": {"type": "string", "format": "date-time"},
    "producedAt": {"type": "string", "format": "date-time"},
    "sourceCount": {"type": "integer", "minimum": 1},
    "coveragePpm": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "stale": {"type": "boolean"},
    "failure": {"type": "string"},
    "items": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema", "id", "observationId", "providerId", "market", "type", "value", "scale", "observedAt", "receivedAt", "effectiveAt", "source", "sourceVersion", "observationHash", "normalizerVersion", "hash"],
        "properties": {
          "schema": {"const": "ynx.oracle.v1"},
          "id": {"type": "string", "minLength": 1},
          "observationId": {"type": "string", "minLength": 1},
          "correctionId": {"type": "string", "minLength": 1},
          "providerId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
          "market": {"type": "string"},
          "type": {"enum": ["ohlcv", "trades", "clob_order_book", "dex_pool_state", "provider_status"]},
          "value": {"const": 0},
          "scale": {"type": "integer", "minimum": 1},
          "liquidity": {"type": "integer", "minimum": 0},
          "volume24h": {"type": "integer", "minimum": 0},
          "candle": {"$ref": "observation.schema.json#/$defs/candle"},
          "trades": {"type": "array", "items": {"$ref": "observation.schema.json#/$defs/trade"}},
          "orderBook": {"$ref": "observation.schema.json#/$defs/orderBook"},
          "poolState": {"$ref": "observation.schema.json#/$defs/poolState"},
          "providerHealth": {"$ref": "observation.schema.json#/$defs/providerHealth"},
          "observedAt": {"type": "string", "format": "date-time"},
          "receivedAt": {"type": "string", "format": "date-time"},
          "effectiveAt": {"type": "string", "format": "date-time"},
          "source": {"type": "string", "minLength": 1},
          "sourceVersion": {"type": "string", "minLength": 1},
          "observationHash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "normalizerVersion": {"const": "observation-normalizer-v1"},
          "hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    }
  }
}
