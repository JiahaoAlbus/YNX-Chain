{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ynx:oracle:v1:observation",
  "title": "YNX Oracle signed provider observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "providerId", "reporterId", "sequence", "nonceDomain", "market", "type", "value", "scale", "observedAt", "source", "sourceVersion", "signatureHex", "hash"],
  "properties": {
    "schema": {"const": "ynx.oracle.v1"},
    "id": {"type": "string", "minLength": 1, "maxLength": 160},
    "providerId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "reporterId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9:_-]{2,127}$"},
    "sequence": {"type": "integer", "minimum": 1},
    "nonceDomain": {"type": "string", "pattern": "^[a-z0-9][a-z0-9:_-]{2,127}$"},
    "market": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._/-]{2,63}$"},
    "type": {"type": "string"},
    "value": {"type": "integer", "minimum": 0},
    "scale": {"type": "integer", "minimum": 1},
    "liquidity": {"type": "integer", "minimum": 0},
    "volume24h": {"type": "integer", "minimum": 0},
    "candle": {"$ref": "#/$defs/candle"},
    "trades": {"type": "array", "minItems": 1, "maxItems": 1000, "items": {"$ref": "#/$defs/trade"}},
    "orderBook": {"$ref": "#/$defs/orderBook"},
    "poolState": {"$ref": "#/$defs/poolState"},
    "providerHealth": {"$ref": "#/$defs/providerHealth"},
    "observedAt": {"type": "string", "format": "date-time"},
    "receivedAt": {"type": "string", "format": "date-time", "readOnly": true},
    "source": {"type": "string", "minLength": 1},
    "sourceVersion": {"type": "string", "minLength": 1},
    "signatureHex": {"type": "string", "pattern": "^[a-f0-9]{128}$"},
    "hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "oneOf": [
    {
      "properties": {"type": {"enum": ["spot_price", "index_price", "mark_price", "funding_reference", "fx", "stablecoin_price", "stablecoin_reserve_ratio", "stablecoin_depeg", "dex_twap", "interest_rate_candidate"]}, "value": {"type": "integer", "minimum": 1}},
      "not": {"anyOf": [{"required": ["candle"]}, {"required": ["trades"]}, {"required": ["orderBook"]}, {"required": ["poolState"]}, {"required": ["providerHealth"]}]}
    },
    {"properties": {"type": {"const": "ohlcv"}, "value": {"const": 0}}, "required": ["candle"]},
    {"properties": {"type": {"const": "trades"}, "value": {"const": 0}}, "required": ["trades"]},
    {"properties": {"type": {"const": "clob_order_book"}, "value": {"const": 0}}, "required": ["orderBook"]},
    {"properties": {"type": {"const": "dex_pool_state"}, "value": {"const": 0}}, "required": ["poolState"]},
    {"properties": {"type": {"const": "provider_status"}, "value": {"const": 0}}, "required": ["providerHealth"]}
  ],
  "$defs": {
    "candle": {
      "type": "object", "additionalProperties": false,
      "required": ["open", "high", "low", "close", "volume", "intervalStart", "intervalEnd"],
      "properties": {"open": {"type": "integer", "minimum": 1}, "high": {"type": "integer", "minimum": 1}, "low": {"type": "integer", "minimum": 1}, "close": {"type": "integer", "minimum": 1}, "volume": {"type": "integer", "minimum": 0}, "intervalStart": {"type": "string", "format": "date-time"}, "intervalEnd": {"type": "string", "format": "date-time"}}
    },
    "trade": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "price", "amount", "side", "at"],
      "properties": {"id": {"type": "string", "minLength": 1}, "price": {"type": "integer", "minimum": 1}, "amount": {"type": "integer", "minimum": 1}, "side": {"enum": ["buy", "sell"]}, "at": {"type": "string", "format": "date-time"}}
    },
    "depthLevel": {
      "type": "object", "additionalProperties": false, "required": ["price", "amount"],
      "properties": {"price": {"type": "integer", "minimum": 1}, "amount": {"type": "integer", "minimum": 1}}
    },
    "orderBook": {
      "type": "object", "additionalProperties": false, "required": ["sequence", "bids", "asks"],
      "properties": {"sequence": {"type": "integer", "minimum": 1}, "bids": {"type": "array", "minItems": 1, "maxItems": 2000, "items": {"$ref": "#/$defs/depthLevel"}}, "asks": {"type": "array", "minItems": 1, "maxItems": 2000, "items": {"$ref": "#/$defs/depthLevel"}}}
    },
    "poolState": {
      "type": "object", "additionalProperties": false,
      "required": ["chainId", "pool", "token0", "token1", "reserve0", "reserve1", "blockNumber", "blockHash"],
      "properties": {"chainId": {"type": "string", "minLength": 1}, "pool": {"type": "string", "minLength": 1}, "token0": {"type": "string", "minLength": 1}, "token1": {"type": "string", "minLength": 1}, "reserve0": {"type": "string", "pattern": "^[0-9]{1,78}$"}, "reserve1": {"type": "string", "pattern": "^[0-9]{1,78}$"}, "blockNumber": {"type": "integer", "minimum": 1}, "blockHash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
    },
    "providerHealth": {
      "type": "object", "additionalProperties": false, "required": ["status", "latencyMillis"],
      "properties": {"status": {"enum": ["up", "degraded", "down"]}, "latencyMillis": {"type": "integer", "minimum": 0}, "lastSuccess": {"type": "string", "format": "date-time"}, "failure": {"type": "string"}}
    }
  }
}
