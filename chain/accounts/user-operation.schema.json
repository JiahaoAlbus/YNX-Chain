{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "YNX UserOperation v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "chainId", "account", "productId", "nonceDomain", "nonce", "calls", "maxFeeYnxt", "validAfter", "validUntil", "signature"],
  "properties": {
    "version": {"const": 1},
    "chainId": {"const": "ynx_6423-1"},
    "account": {"type": "string", "pattern": "^ynx1[0-9a-z]+$"},
    "productId": {"type": "string", "minLength": 1, "maxLength": 128},
    "nonceDomain": {"type": "string", "minLength": 1, "maxLength": 256},
    "nonce": {"type": "integer", "minimum": 0},
    "calls": {
      "type": "array", "minItems": 1, "maxItems": 64,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["target", "method", "valueYnxt", "payloadHash"],
        "properties": {
          "target": {"type": "string", "minLength": 1, "maxLength": 256},
          "method": {"type": "string", "minLength": 1, "maxLength": 128},
          "valueYnxt": {"type": "integer", "minimum": 0},
          "asset": {"type": "string", "minLength": 1, "maxLength": 64},
          "payloadHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "maxFeeYnxt": {"type": "integer", "minimum": 0},
    "validAfter": {"type": "string", "format": "date-time"},
    "validUntil": {"type": "string", "format": "date-time"},
    "sessionKeyId": {"type": "string", "minLength": 1, "maxLength": 256},
    "paymasterPolicy": {"type": "string", "minLength": 1, "maxLength": 256},
    "signature": {"type": "string", "contentEncoding": "base64"}
  }
}
