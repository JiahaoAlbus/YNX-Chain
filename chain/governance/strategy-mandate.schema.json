{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "YNX StrategyMandate v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "chainId", "id", "owner", "engineIdentity", "strategyHash", "strategyVersion", "venues", "assets", "markets", "methods", "capitalLimitYnxt", "positionLimitYnxt", "maxLeverageBps", "maxSlippageBps", "dailyLossLimitYnxt", "drawdownLimitBps", "validAfter", "expiresAt", "nonceDomain", "nextNonce", "createdAt", "auditHash"],
  "properties": {
    "schemaVersion": {"const": 1},
    "chainId": {"const": "ynx_6423-1"},
    "id": {"type": "string", "minLength": 1, "maxLength": 256},
    "owner": {"type": "string", "minLength": 1, "maxLength": 256},
    "engineIdentity": {"type": "string", "minLength": 1, "maxLength": 256},
    "strategyHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "strategyVersion": {"type": "integer", "minimum": 1},
    "venues": {"$ref": "#/$defs/stringSet"},
    "assets": {"$ref": "#/$defs/stringSet"},
    "markets": {"$ref": "#/$defs/stringSet"},
    "methods": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["place_order", "cancel_order", "reduce_position", "rebalance", "settle"]}},
    "capitalLimitYnxt": {"type": "integer", "minimum": 1},
    "positionLimitYnxt": {"type": "integer", "minimum": 1},
    "maxLeverageBps": {"type": "integer", "minimum": 10000, "maximum": 1000000},
    "maxSlippageBps": {"type": "integer", "minimum": 0, "maximum": 10000},
    "dailyLossLimitYnxt": {"type": "integer", "minimum": 1},
    "drawdownLimitBps": {"type": "integer", "minimum": 0, "maximum": 10000},
    "validAfter": {"type": "string", "format": "date-time"},
    "expiresAt": {"type": "string", "format": "date-time"},
    "nonceDomain": {"type": "string", "minLength": 1, "maxLength": 256},
    "nextNonce": {"type": "integer", "minimum": 0},
    "revokedAt": {"type": "string", "format": "date-time"},
    "killSwitchAt": {"type": "string", "format": "date-time"},
    "createdAt": {"type": "string", "format": "date-time"},
    "auditHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "stringSet": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}}
  }
}
